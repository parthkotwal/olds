# ── News API keys ─────────────────────────────────────────────────────────────
# NewsAPI: https://newsapi.org/register (free tier: 100 req/day)
NEWSAPI_KEY=your_newsapi_key_here

# The Guardian Open Platform: https://open-platform.theguardian.com/access/
# Optional — provides full article body text (NewsAPI free tier truncates at ~200 chars).
GUARDIAN_KEY=your_guardian_key_here

# ── Database ───────────────────────────────────────────────────────────────────
# Supabase hosted Postgres with pgvector enabled.
# Use the Session Pooler connection string (aws-0-*.pooler.supabase.com:5432)
# not the direct connection string (db.*.supabase.co:5432) — Docker containers
# cannot reach IPv6 addresses, and the direct string resolves to IPv6.
# Find it in: Supabase dashboard → Settings → Database → Session pooler
SUPABASE_DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── Supabase Auth ──────────────────────────────────────────────────────────────
# Project URL — used by the frontend Supabase client.
# Find it in: Supabase dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key — safe to expose to the browser. Used by the frontend.
# Find it in: Supabase dashboard → Settings → API → Project API keys → anon public
SUPABASE_ANON_KEY=eyJ...your_anon_key_here

# JWT secret — used by the Go backend to verify Supabase-issued tokens.
# NEVER expose this to the frontend or commit it to git.
# Find it in: Supabase dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ── LLM (Phase 15) ─────────────────────────────────────────────────────────────
# OpenAI/Anthropic API key — used by the Go backend to generate connection explanations.
# Scoped to connection explanations only (see CLAUDE.md guardrails).
# If unset, connections are shown without explanation text (graceful degradation).
LLM_API_KEY=sk-...

# ── CORS (Production) ──────────────────────────────────────────────────────────
# The deployed frontend origin, used by the Go backend for CORS.
# Set this in Railway to your frontend Railway URL (e.g. https://olds-frontend.up.railway.app).
# If unset, the backend falls back to "*" — fine for local dev, lock down in production.
FRONTEND_URL=https://your-frontend-url.up.railway.app

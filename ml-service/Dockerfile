# Dockerfile for the Olds ML service (Python + FastAPI).
#
# This service handles NER only (spaCy). Embeddings are generated by the
# Go backend via OpenAI's text-embedding-3-small API.
#
# Without sentence-transformers/PyTorch, the image is ~200MB instead of ~1.5GB.

FROM python:3.11-slim

WORKDIR /app

# ── System dependencies ───────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# ── Python dependencies ───────────────────────────────────────────────────────
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# ── Bake spaCy model into the image ──────────────────────────────────────────
RUN pip install --no-cache-dir \
    https://github.com/explosion/spacy-models/releases/download/en_core_web_sm-3.7.1/en_core_web_sm-3.7.1-py3-none-any.whl

# ── Application source ────────────────────────────────────────────────────────
COPY app/ ./app/

EXPOSE 8001

CMD uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8001}
